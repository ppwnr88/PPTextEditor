{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PPText Editor",
  "version": "0.1.1",
  "identifier": "com.ppwnr.subtext",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PPText Editor",
        "width": 1480,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
